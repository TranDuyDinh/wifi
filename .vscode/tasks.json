{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Release Python: Current File",
            "type": "shell",
            "command": "python",
            "args": ["-O", "${file}"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Release Python: main.py",
            "type": "shell",
            "command": "python",
            "args": ["-O", "${workspaceFolder}/main.py"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
